{
  "name": "@simtalk/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "start": "node --env-file-if-exists=.env dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "2.0.3",
    "@simtalk/shared-types": "workspace:0.0.0",
    "hono": "4.12.21",
    "livekit-server-sdk": "^2.15.3"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
