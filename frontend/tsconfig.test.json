{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@simtalk/shared-types": ["../shared/types/src/index.ts"],
      "@testing-library/jest-dom/vitest": [
        "./node_modules/@testing-library/jest-dom/types/vitest.d.ts"
      ],
      "@testing-library/react": [
        "./node_modules/@testing-library/react/types/index.d.ts"
      ],
      "react": ["./node_modules/@types/react/index.d.ts"],
      "react-dom": ["./node_modules/@types/react-dom/index.d.ts"],
      "livekit-client": ["./node_modules/livekit-client/dist/src/index.d.ts"],
      "react/jsx-dev-runtime": [
        "./node_modules/@types/react/jsx-dev-runtime.d.ts"
      ],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime.d.ts"],
      "vitest": ["./node_modules/vitest/dist/index.d.ts"],
      "vitest/config": ["./node_modules/vitest/config.d.ts"]
    }
  },
  "include": ["src", "../tests/frontend/**/*.ts", "../tests/frontend/**/*.tsx"]
}
