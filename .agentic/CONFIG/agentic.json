{
  "version": 2,
  "graph": {
    "provider": "understand-anything",
    "path": ".understand-anything/knowledge-graph.json",
    "required": true,
    "fallback": "codemap",
    "dependency_edge_types": ["imports", "calls", "depends_on", "references"],
    "test_edge_types": ["tested_by", "tests"],
    "dependency_fanout": 4
  },
  "routing": {
    "budgets": { "anchors": 6, "deps": 4, "search": 6, "tests": 4 },
    "hard_cap": 12,
    "min_search_score_with_anchors": 3
  },
  "subsystem_path_roots": {
    "frontend": "web",
    "backend": "api",
    "shared": "shared",
    "tests": "tests",
    ".github": "infra",
    "api": "api"
  },
  "paths": {
    "memory_root": ".agentic",
    "scripts_root": "scripts/agentic",
    "context_cache": ".agentic/CONTEXT/last_context.json"
  },
  "freshness_rules": {
    "graph_max_age_hours": 168,
    "memory_max_age_days": 30
  },
  "validation": {
    "require_region_markers": true,
    "sample_path_check_count": 5
  },
  "ignore_globs": [
    "**/node_modules/**",
    "**/.venv/**",
    "**/venv/**",
    "**/dist/**",
    "**/build/**",
    "**/.next/**",
    "**/.turbo/**",
    "**/.cache/**",
    "**/.git/**",
    "**/__pycache__/**",
    "**/*.lock",
    "**/coverage/**",
    "**/.vercel/**",
    "**/.pnpm-store/**",
    "**/.pnpm/**",
    "**/.vite/**",
    "**/.pytest_cache/**",
    "**/playwright-report/**",
    "**/test-results/**",
    "**/.DS_Store"
  ],
  "test_discovery": [
    "**/tests/**",
    "**/__tests__/**",
    "**/*.test.*",
    "**/*.spec.*",
    "**/*_test.*",
    "**/test_*.py"
  ],
  "high_risk_patterns": [
    { "match": "**/auth/**", "tags": ["security", "authn"], "keywords": ["auth", "login", "authn", "authz"] },
    { "match": "**/middleware/**", "tags": ["security"], "keywords": ["middleware", "cors", "ratelimit"] },
    { "match": "**/secrets/**", "tags": ["secrets"], "keywords": ["secret", "secrets"] },
    { "match": "**/.env*", "tags": ["secrets"], "keywords": ["env", "secret", "key"] },
    { "match": "**/realtime/**", "tags": ["realtime", "latency"], "keywords": ["realtime", "webrtc", "latency"] },
    { "match": "**/webrtc/**", "tags": ["realtime", "latency"], "keywords": ["webrtc", "rtc", "peerconnection"] },
    { "match": "**/recording/**", "tags": ["privacy"], "keywords": ["recording", "record", "transcript"] },
    { "match": "**/infra/**", "tags": ["infra"], "keywords": ["infra", "deploy", "vercel"] },
    { "match": "**/.github/workflows/**", "tags": ["infra", "ci"], "keywords": ["ci", "workflow", "github-actions"] },
    { "match": "**/Dockerfile", "tags": ["infra"], "keywords": ["dockerfile", "docker", "container"] }
  ],
  "subsystem_keywords": {
    "web": [
      "ui",
      "page",
      "component",
      "view",
      "react",
      "vite",
      "frontend",
      "browser",
      "transcript",
      "playback",
      "microphone",
      "mic"
    ],
    "api": [
      "api",
      "endpoint",
      "route",
      "controller",
      "handler",
      "hono",
      "backend",
      "token",
      "ephemeral",
      "rate-limit",
      "cors",
      "schema",
      "zod",
      "middleware"
    ],
    "shared": ["shared", "types", "contract", "dto"],
    "tests": [
      "test",
      "tests",
      "vitest",
      "playwright",
      "e2e",
      "integration",
      "unit",
      "coverage"
    ],
    "infra": [
      "deploy",
      "vercel",
      "cloud-run",
      "gcp",
      "ci",
      "github-actions",
      "workflow",
      "dockerfile",
      "env",
      "environment"
    ]
  },
  "generated_artifacts": [
    ".agentic/CONTEXT/last_context.json",
    ".agentic/CONTEXT/last_update_ref"
  ]
}
